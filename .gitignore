# =============================================================================
# Journal Intelligence Dashboard — .gitignore
# =============================================================================

# =============================================================================
# CRITICAL — Personal data, secrets, credentials
# NEVER commit these under any circumstances
# =============================================================================

# Your actual config (JWT secret, API keys, etc.)
config/config.yaml

# Your entire journal database
db/
*.db
*.db-wal
*.db-shm

# All personal journal data
data/

# Logs (auth events, IP addresses, API activity)
logs/
*.log
*.jsonl

# Backups
backups/
*.bak
*.backup
*.tar.gz

