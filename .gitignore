# =============================================================================
# Project-specific: dev/deploy artifacts that contain personal info
# =============================================================================

# Handoff docs — contain server details, API key prefixes, personal narrative
handoff*.md

# One-off patch/fix/deploy scripts used during development
patch_*.py
fix_*.py
deploy_*.py
backfill_*.py

# Demo data generators (contain personal narrative arc)
generate_demo_*.py

# Old migration scripts (already ran, don't need in repo)
migrate_user_isolation.sql
migration_api_keys.sql
migration_reflection_cache.sql
migration_user_memory.sql
migration_user_settings.sql

# Old versioned/duplicate files
App_updated.jsx
*_patch.jsx
*_patch.py
main_additions.py
main_export_routes.py
main_upload_patch.py

# Dev docs that reference personal server setup
chatgptNGINXconfigfix.md
shortcut_troubleshooting.md
entry_commands.md
delete_user_fix.md
exit_plan_spec.md

# Old project instruction versions (keep latest only)
PROJECT_INSTRUCTIONS_v4.md
PROJECT_INSTRUCTIONS_v5.md

# nohup output
nohup.out

# Temp files
*.tmp
*.temp
tmp/
temp/

